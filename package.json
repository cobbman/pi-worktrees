{
  "name": "@cobbman/pi-worktrees",
  "version": "0.1.0",
  "description": "Secure git worktree management extension for Pi Coding Agent",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/cobbman/pi-worktrees.git"
  },
  "bugs": {
    "url": "https://github.com/cobbman/pi-worktrees/issues"
  },
  "homepage": "https://github.com/cobbman/pi-worktrees#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "lint": "eslint .",
    "prepack": "npm run build",
    "prepublishOnly": "npm test && npm run typecheck && npm run lint && npm run build"
  },
  "keywords": [
    "pi-package",
    "git-worktrees"
  ],
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@zenobius/pi-extension-config": "^0.2.0",
    "typebox": "^1.0.81"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "@types/node": "^20.11.5",
    "@typescript-eslint/eslint-plugin": "8.47.0",
    "@typescript-eslint/parser": "8.47.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.2.4",
    "typescript-eslint": "^8.47.0",
    "vitest": "^3.2.4"
  }
}
